# PocketPay Contracts — Environment Variables
#
# This file is for documentation only. Do not commit real secrets.
# Copy to .env and fill in your values.
#
# For full deployment environment details, see docs/deployment-environments.md

# Deployed savings vault contract ID (testnet)
# Get this value from your deploy command output
# VAULT_CONTRACT_ID=

# Soroban RPC URL override (optional — defaults to testnet)
# SOROBAN_RPC_URL=https://soroban-testnet.stellar.org:443

# Soroban network passphrase override (optional — defaults to testnet)
# SOROBAN_NETWORK_PASSPHRASE=Test SDF Network ; September 2015
